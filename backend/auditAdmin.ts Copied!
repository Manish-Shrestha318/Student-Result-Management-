import mongoose from "mongoose";
import dotenv from "dotenv";
import User from "./src/models/User";
import bcrypt from "bcryptjs";

dotenv.config();

const auditAdmin = async () => {
    try {
        console.log("Connecting to:", process.env.MONGO_URI);
        await mongoose.connect(process.env.MONGO_URI as string);
        
        const adminEmail = "admin@test.com";
        const hashedPassword = await bcrypt.hash("123456", 10);
        
        let user: any = await User.findOne({ email: adminEmail });
        
        if (!user) {
            console.log("Admin not found. Creating new admin...");
            user = await User.create({
              name: "System Admin",
              email: adminEmail,
              password: hashedPassword,
              status: "active",
              role: "admin"
            });
        } else {
            console.log("Current User in DB:", {
                id: user._id,
                email: user.email,
                role: user.role,
                status: user.status,
                hasPassword: !!user.password,
                googleId: user.googleId || "None"
            });
            
            user.password = hashedPassword;
            user.status = "active";
            user.role = "admin";
            await user.save();
            console.log("Password updated for existing admin.");
        }
        
        console.log("Repair verification complete.");
        process.exit(0);
    } catch (err: any) {
        console.error("Audit/Repair failed:", err.message);
        process.exit(1);
    }
};

auditAdmin();
